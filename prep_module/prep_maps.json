            "to": "rename"
        }
    },
    ".v2021_2_1.BulkRenameColumns": {
        "type": "bulk_rename",
        "column": [
            "columnsSelection",
            "columnsOperation"
        ],
        "field_target": {
            "selection_type": {
                "column": "columnsSelection",
                "path": ["selectionRule", "type"],
                "mode": "scalar"
            },
            "column_substr": {
                "column": "columnsSelection",
                "path": ["selectionRule", "columnNameSubStr"],
                "mode": "scalar"
            },
            "included_columns": {
                "column": "columnsSelection",
                "path": ["includedColumns"],
                "mode": "scalar"
            },
            "exempted_columns": {
                "column": "columnsSelection",
                "path": ["exemptedColumns"],
                "mode": "scalar"
            },
            "operation_type": {
                "column": "columnsOperation",
                "path": ["type"],
                "mode": "scalar"
            },
            "column_name_prefix": {
                "column": "columnsOperation",
                "path": ["columnNamePrefix"],
                "mode": "scalar"
            },
            "column_name_suffix": {
                "column": "columnsOperation",
                "path": ["columnNameSuffix"],
                "mode": "scalar"
            },            "existing_subString": {
                "column": "columnsOperation",
                "path": ["existingSubString"],
                "mode": "scalar"
            },
            "new_substring": {
                "column": "columnsOperation",
                "path": ["newSubString"],
                "mode": "scalar"
            }
        }
    },
