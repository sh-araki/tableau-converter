        "type": "unpivot",
        "column": [
            "usesSmartDefaults", 
            "unpivotGroup"
        ],
        "field_target": {
            "name": {
                "column": "unpivotGroup",
                "path": ["literalColumn", "literalColumnName"],
                "mode": "scalar"
            },
            "unpivot_columns": {
                "column": "unpivotGroup",
                "path": ["unpivotColumns"],
                "mode": "explode",
                "child_columns": {
                    "name": {
                        "column": "unpivotColumnName",
                        "path": [],
                        "mode": "scalar"
                    },
                    "bindings_type": {
                        "column": "columnInformation",
                        "path": ["bindingsType"],
                        "mode": "scalar"
                    },
                    "manual_bindings": {
                        "column": "columnInformation",
                        "path": ["manualBindings"],
                        "mode": "scalar"
                    },
                    "wildcard_type": {
                        "column": "columnInformation",
