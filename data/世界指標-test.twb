      <column datatype='integer' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[1 人当たりの医療費]' role='measure' type='quantitative' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0nwrb8b1xoqnsf1dnja360y7cceu].[avg:Calculation_638103803600809984:qk]&quot;' value='平均寿命' />
          <alias key='&quot;[federated.0nwrb8b1xoqnsf1dnja360y7cceu].[avg:乳児死亡率:qk]&quot;' value='乳児死亡' />
