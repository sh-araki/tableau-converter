    <dashboard name='世界指標' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run>世界の成長と発展を示す指標</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='background-color' value='#c0c0c0' />
        </style-rule>
      </style>
      <size minheight='620' minwidth='1000' sizing-mode='range' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='100000' id='1' param='vert' removable='false' type-v2='layout-flow' w='100000' x='0' y='0'>
            <zone h='5323' id='3' type-v2='title' w='100000' x='0' y='0' />
            <zone fixed-size='125' h='20161' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='100000' x='0' y='5323' />
            <zone h='74516' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='100000' x='0' y='25484'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='世界の人口と出生率は不均衡です。' captured-sheet='人口' id='1' />
                  <story-point caption='GDP の 14% 以上を医療に費やしている国もいくつかあります。' captured-sheet='医療費' id='2' />
                  <story-point caption='携帯電話の使用量は、インターネットの使用量よりもはるかに速く伸びています。' captured-sheet='テクノロジー' id='3'>
                    <capturedDeltas>
                      <worksheet name='テクノロジー'>
                        <filter class='categorical' column='[federated.0nwrb8b1xoqnsf1dnja360y7cceu].[none:地域:nk]'>
                          <groupfilter function='member' level='[none:地域:nk]' member='&quot;南北アメリカ&quot;' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='経済がマイナス成長になると、金利が低下すると見ています。' captured-sheet='経済' id='4'>
                    <capturedDeltas>
                      <worksheet name='経済'>
                        <filter class='categorical' column='[federated.0nwrb8b1xoqnsf1dnja360y7cceu].[none:地域:nk]'>
                          <groupfilter function='member' level='[none:地域:nk]' member='&quot;アフリカ&quot;' user:ui-domain='relevant' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
                        </filter>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='観光地として最も人気があるのは、引き続きヨーロッパです。' captured-sheet='ツーリズム' id='5' />
                  <story-point caption='GDP の高さはビジネスのしやすさと相関があります。' captured-sheet='事業' id='6' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
        </zone>
      </zones>
      <simple-id uuid='{4DE30101-A558-41D9-AE1A-037E56925E62}' />
    </dashboard>
