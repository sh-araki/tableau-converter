          <alias key='&quot;[federated.0nwrb8b1xoqnsf1dnja360y7cceu].[usr:Calculation_1554586357507932164:qk]&quot;' value='1 人当たりの GDP' />
        </aliases>
      </column>
      <column caption='しきい値を上回るか?' datatype='string' name='[Calculation_1554586357494272000]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [対 GDP 比医療費]&gt;[Parameters].[Parameter 1] then &quot;しきい値を上回る&quot; else &quot;しきい値を下回る&quot; end' />
      </column>
      <column caption='1 人当たりの GDP' datatype='real' default-format='c&quot;$&quot;#,##0' name='[Calculation_1554586357495853057]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[GDP]/[総人口]' />
      </column>
      <column caption='出生率ビン' datatype='string' name='[Calculation_1554586357496451074]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if ([出生率])&lt;0.015 then &quot;1.5% 未満&quot; elseif&#13;&#10;([出生率])&lt;0.03 then &quot;1.5 ～ 3%&quot; else&#13;&#10;&quot;3% を越える&quot; end' />
      </column>
      <column caption='平均寿命' datatype='real' default-format='n#,##0' name='[Calculation_638103803600809984]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([平均寿命 (女性)]+[平均寿命 (男性)])/2' />
      </column>
      <column aggregation='Avg' datatype='integer' default-format='c&quot;$&quot;#,##0,,,B;(&quot;$&quot;#,##0,,,B)' name='[GDP]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
