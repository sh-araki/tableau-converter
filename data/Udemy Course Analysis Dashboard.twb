            </column>
            <column caption='Total Reviews' datatype='integer' name='[Calculation_406449907142811671]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='TOTAL(SUM([NUM_REVIEWS]))'>
                <table-calc ordering-type='Rows' />
