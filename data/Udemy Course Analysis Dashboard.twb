            <column caption=' CY Reviews' datatype='integer' name='[ CY Students (copy)_1653102583048757259]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF Year = [Parameters].[Year Parameter] &#13;&#10;THEN [NUM_REVIEWS]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Subject Selector' datatype='boolean' name='[Calculation_1114359477219618816]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[SUBJECT] = [Parameters].[Subject Parameter]' />
